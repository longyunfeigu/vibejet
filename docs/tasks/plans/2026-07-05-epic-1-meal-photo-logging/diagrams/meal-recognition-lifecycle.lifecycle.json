  "transitions": [
    { "from": "submit", "to": "recognizing", "variant": "emphasis" },
    { "from": "recognizing", "to": "ready", "label": "结构化明细", "variant": "emphasis", "fromSide": "bottom", "toSide": "top", "labelDx": 90, "labelDy": -14 },
    { "from": "recognizing", "to": "unavailable", "label": "超时/5xx", "variant": "security", "fromSide": "bottom", "toSide": "right" },
    { "from": "recognizing", "to": "unrecognized", "label": "低置信度", "fromSide": "bottom", "toSide": "top" },
    { "from": "unavailable", "to": "submit", "label": "重试", "fromSide": "left", "toSide": "bottom" },
    { "from": "unrecognized", "to": "submit", "label": "文本补录", "fromSide": "left", "toSide": "bottom" }
  ],
  "cards": []
