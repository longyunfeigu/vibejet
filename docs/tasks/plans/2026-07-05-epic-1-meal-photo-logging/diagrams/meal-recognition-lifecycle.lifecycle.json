  "states": [
    { "id": "submit", "type": "start", "label": "提交", "sublabel": "photo_id 或 text", "lane": "main", "col": 0, "step": "01" },
    { "id": "recognizing", "type": "active", "label": "识别中", "sublabel": "同步等待 ≤10s", "lane": "main", "col": 2, "step": "02", "tag": "零落库" },
    { "id": "unavailable", "type": "waiting", "label": "服务不可用", "sublabel": "AI_UNAVAILABLE · 503", "lane": "waiting", "col": 0 },
    { "id": "unrecognized", "type": "waiting", "label": "无法识别", "sublabel": "200 · reason", "lane": "waiting", "col": 2 },
    { "id": "ready", "type": "success", "label": "结果就绪", "sublabel": "进入确认区", "lane": "terminal", "col": 1 }
