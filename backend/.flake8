[flake8]
max-line-length = 100
extend-ignore = E203, E501, W503
exclude =
    .git
    __pycache__
    build
    dist
    .venv
    venv
    alembic/versions
    grpc_app/generated
max-complexity = 10
# scripts/ 与 alembic/env.py 属 CLI/迁移工具，print 为合法输出，仅豁免 T20（flake8-print）
per-file-ignores =
    __init__.py:F401
    scripts/*.py:T201,T203
    alembic/env.py:T201,T203
