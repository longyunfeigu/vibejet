{
    "version": "1.0",
    "description": "Skill activation triggers for Claude Code. Controls when skills automatically suggest or block actions.",
    "skills": {
        "skill-developer": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Meta-skill for creating and managing Claude Code skills",
            "promptTriggers": {
                "keywords": [
                    "skill system",
                    "create skill",
                    "add skill",
                    "skill triggers",
                    "skill rules",
                    "hook system",
                    "skill development",
                    "skill-rules.json"
                ],
                "intentPatterns": [
                    "(how do|how does|explain).*?skill",
                    "(create|add|modify|build).*?skill",
                    "skill.*?(work|trigger|activate|system)"
                ]
            }
        },
        "backend-dev-guidelines": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "high",
            "description": "Backend development patterns for Python (Django/FastAPI/Flask), Golang (Gin/Echo/Fiber), and Java (Spring Boot)",
            "promptTriggers": {
                "keywords": [
                    "backend",
                    "backend development",
                    "microservice",
                    "controller",
                    "service",
                    "repository",
                    "route",
                    "routing",
                    "handler",
                    "API",
                    "endpoint",
                    "middleware",
                    "validation",
                    "database access",
                    "dependency injection",
                    "configuration",
                    "Django",
                    "FastAPI",
                    "Flask",
                    "Gin",
                    "Echo",
                    "Fiber",
                    "Spring Boot",
                    "Spring MVC",
                    "RestController",
                    "ORM",
                    "SQLAlchemy",
                    "GORM",
                    "JPA",
                    "Hibernate"
                ],
                "intentPatterns": [
                    "(create|add|implement|build).*?(route|endpoint|API|controller|service|repository|handler)",
                    "(fix|handle|debug).*?(error|exception|backend)",
                    "(add|implement).*?(middleware|validation|error.*?handling|interceptor)",
                    "(organize|structure|refactor).*?(backend|service|API)",
                    "(how to|best practice).*?(backend|route|controller|service|handler)",
                    "(setup|configure).*?(database|ORM|connection|model)"
                ]
            },
            "fileTriggers": {
                "pathPatterns": [
                    "**/backend/**/*.py",
                    "**/api/**/*.py",
                    "**/app/**/*.py",
                    "**/src/**/*.py",
                    "**/views/**/*.py",
                    "**/handlers/**/*.py",
                    "**/controllers/**/*.py",
                    "**/services/**/*.py",
                    "**/repositories/**/*.py",
                    "**/backend/**/*.go",
                    "**/api/**/*.go",
                    "**/cmd/**/*.go",
                    "**/internal/**/*.go",
                    "**/pkg/**/*.go",
                    "**/handlers/**/*.go",
                    "**/controllers/**/*.go",
                    "**/services/**/*.go",
                    "**/repositories/**/*.go",
                    "**/backend/**/*.java",
                    "**/api/**/*.java",
                    "**/src/main/java/**/*.java",
                    "**/controller/**/*.java",
                    "**/service/**/*.java",
                    "**/repository/**/*.java",
                    "**/handler/**/*.java"
                ],
                "pathExclusions": [
                    "**/*_test.py",
                    "**/*_test.go",
                    "**/*Test.java",
                    "**/*Tests.java",
                    "**/test_*.py",
                    "**/tests/**",
                    "**/venv/**",
                    "**/node_modules/**",
                    "**/target/**",
                    "**/build/**"
                ],
                "contentPatterns": [
                    "@app\\.route",
                    "@router\\.",
                    "@api_view",
                    "class.*View",
                    "class.*ViewSet",
                    "def.*handler",
                    "async def",
                    "func.*Handler",
                    "func.*Controller",
                    "http\\.HandleFunc",
                    "router\\.",
                    "gin\\.Context",
                    "echo\\.Context",
                    "fiber\\.Ctx",
                    "@RestController",
                    "@Controller",
                    "@Service",
                    "@Repository",
                    "@RequestMapping",
                    "@GetMapping",
                    "@PostMapping",
                    "@PutMapping",
                    "@DeleteMapping",
                    "@Autowired",
                    "extends.*Controller",
                    "implements.*Service"
                ]
            }
        },
        "vj-feature": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "medium",
            "description": "给已有项目追加功能。从功能想法出发，通过对话澄清需求，生成或追加 Epic/Story，可选同步 PRD，最后路由到实现。",
            "promptTriggers": {
                "keywords": [
                    "加功能",
                    "新功能",
                    "添加功能",
                    "增加功能",
                    "加一个",
                    "我想加",
                    "新增功能",
                    "feature",
                    "add feature",
                    "new feature"
                ],
                "intentPatterns": [
                    "(加|添加|增加|新增|做一个|搞一个).*?(功能|能力|模块|系统)",
                    "(我想|我要|我们要|需要).*(加|添加|增加|做).*?(功能|能力|特性)",
                    "(add|implement|build|create).*?(feature|capability|module)"
                ]
            }
        },
        "vj-design-md-matcher": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "medium",
            "description": "产品/品牌方向轨：根据产品级 UI brief 或 PRD 从 vibeui / awesome-design-md 推荐参考 DESIGN.md，生成 docs/project/DESIGN.md 与 golden screens；只用于低频设计定向，不用于单屏结构/状态补全，也不在实现阶段临时选风格",
            "promptTriggers": {
                "keywords": [
                    "DESIGN.md",
                    "design-md",
                    "awesome-design-md",
                    "vibeui",
                    "设计库匹配",
                    "风格库推荐",
                    "参考 DESIGN",
                    "生成项目 DESIGN",
                    "项目设计系统",
                    "自动匹配设计",
                    "品牌感",
                    "整体视觉",
                    "golden screen",
                    "golden screens"
                ],
                "intentPatterns": [
                    "(匹配|推荐|选择|挑).*?(DESIGN\\.md|design-md|设计库|风格库)",
                    "(根据|基于).*?(PRD|需求).*?(推荐|匹配).*?(设计|DESIGN\\.md)",
                    "(生成|产出|创建).*?(项目|自己的).*?DESIGN\\.md",
                    "(整体|全局|统一).*?(设计|ui|视觉|风格|品牌)",
                    "(vibeui|awesome-design-md).*?(匹配|推荐|参考)"
                ]
            }
        },
        "vj-mock-board": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "medium",
            "description": "PRD → 单文件 UI mock board：解析 PRD 出 Screen Inventory，按 docs/project/DESIGN.md 双轨 token 生成按 Epic 分区平铺的 mock HTML 板（含每屏 API/设计决策注记），写代码前看到产品长什么样；缺 DESIGN.md 先走 vj-design-md-matcher，不用于实现期选风格",
            "promptTriggers": {
                "keywords": [
                    "mock board",
                    "mock html",
                    "ui mock",
                    "mockup",
                    "wireframe",
                    "原型板",
                    "界面草图",
                    "线框图",
                    "出 mock",
                    "画个原型",
                    "产品长什么样",
                    "PRD 转界面"
                ],
                "intentPatterns": [
                    "(根据|基于|按).*?(PRD|需求文档|requirements).*?(mock|原型|界面|长什么样|画)",
                    "(出|画|生成|做).*?(mock|原型板|线框|界面草图|mockup|wireframe)",
                    "(看看|想看|预览).*?(产品|界面|页面).*?(长什么样|样子|效果)",
                    "mock.*?(board|html|页面|界面)"
                ]
            }
        },
        "vj-epic-plan": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "medium",
            "description": "以一个 Epic（含若干 Story）为单元生成适合人工 Review 且可供下游执行的实现计划（HOW）：共享设计（人工 review 主面：ERD/流程图/边界/术语，决策内联进图）、§0 审批门（待拍板决策）、跨 epic 契约、实现单元与依赖图；命中 API 或持久化变化时同步维护 docs/project/api/ 与 docs/project/data/ 模块化契约目录。",
            "promptTriggers": {
                "keywords": [
                    "epic plan",
                    "epic 计划",
                    "epic 实现计划",
                    "规划 epic",
                    "epic 详规",
                    "给 epic 出计划",
                    "epic 级计划",
                    "epic-plan",
                    "plan epic"
                ],
                "intentPatterns": [
                    "(规划|计划|出|做).*?epic",
                    "epic.*?(实现计划|详规|plan|计划)",
                    "(给|为).*?epic.*?(计划|plan|实现)"
                ]
            }
        },
        "vj-compound": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "low",
            "description": "把刚解决的问题/刚确立的决策沉淀为 docs/solutions/ 下的结构化学习文档（YAML frontmatter，可被 vj-learnings-researcher 检索）。学习飞轮的写端。",
            "promptTriggers": {
                "keywords": [
                    "沉淀",
                    "compound",
                    "记录这次",
                    "存经验",
                    "踩坑记录",
                    "沉淀经验",
                    "记录踩坑",
                    "把经验存",
                    "知识沉淀",
                    "学习沉淀"
                ],
                "intentPatterns": [
                    "(沉淀|记录|存).*?(经验|踩坑|决策|教训|问题)",
                    "(把|将).*?(这个|这次|经验|决策).*(沉淀|记录|存)",
                    "compound"
                ]
            }
        },
        "story-reference-impl": {
            "type": "domain",
            "enforcement": "suggest",
            "priority": "medium",
            "description": "参考开源项目实现复杂 Story。结构化研究源码，提取核心设计，适配 DDD 架构后实现。",
            "promptTriggers": {
                "keywords": [
                    "参考",
                    "开源",
                    "类似",
                    "借鉴",
                    "reference",
                    "open source",
                    "similar to",
                    "like in",
                    "inspired by",
                    "参考实现",
                    "源码分析"
                ],
                "intentPatterns": [
                    "(参考|借鉴|模仿|学习|分析).*?(项目|实现|源码|设计|架构)",
                    "(类似|像|仿照).*?(功能|特性|实现|模块)",
                    "(reference|look at|similar to|like in|inspired by|based on).*?(project|implementation|repo|codebase)",
                    "(how does|how do).*?(implement|build|design).*?(in|at).*?(project|repo)"
                ]
            }
        },
        "frontend-dev-guidelines": {
            "type": "guardrail",
            "enforcement": "block",
            "priority": "high",
            "description": "vibejet 前端规范：React + Vite + TS + Tailwind v4 + shadcn/ui + TanStack（不用 MUI）",
            "promptTriggers": {
                "keywords": [
                    "component",
                    "react component",
                    "UI",
                    "interface",
                    "page",
                    "modal",
                    "dialog",
                    "form",
                    "Tailwind",
                    "shadcn",
                    "styling",
                    "frontend",
                    "React"
                ],
                "intentPatterns": [
                    "(create|add|make|build|update|modify|edit).*?(component|UI|page|modal|dialog|form)",
                    "(how to|best practice).*?(component|react|tailwind|shadcn)",
                    "(style|design|layout).*?(component|UI)"
                ]
            },
            "fileTriggers": {
                "pathPatterns": [
                    "frontend/src/**/*.tsx",
                    "frontend/src/**/*.ts",
                    "src/**/*.tsx"
                ],
                "pathExclusions": [
                    "**/*.test.tsx",
                    "**/*.test.ts",
                    "**/*.spec.tsx",
                    "**/*.spec.ts",
                    "**/components/ui/**",
                    "**/routeTree.gen.ts",
                    "**/vite.config.ts",
                    "**/tsconfig.json"
                ],
                "contentPatterns": [
                    "from '@mui",
                    "@material-ui",
                    "sx={",
                    "makeStyles",
                    "createTheme"
                ]
            },
            "blockMessage": "⚠️ BLOCKED - Frontend Best Practices Required\n\n📋 REQUIRED ACTION:\n1. Use Skill tool: 'frontend-dev-guidelines'\n2. 本项目用 Tailwind v4 + shadcn/ui，禁用 MUI / emotion / sx。检测到 MUI 残留请改写为 Tailwind class + shadcn 组件\n3. 样式 token 来自 docs/project/DESIGN.md → src/index.css，不要硬编码 hex\n4. 数据用 useSuspenseQuery + <SuspenseLoader>，不写 early-return loading\n5. Then retry this edit\n\nReason: Enforce Tailwind+shadcn stack (no MUI) and React best practices\nFile: {file_path}\n\n💡 TIP: Add '// @skip-validation' comment to skip future checks",
            "skipConditions": {
                "sessionSkillUsed": true,
                "fileMarkers": [
                    "@skip-validation"
                ],
                "envOverride": "SKIP_FRONTEND_GUIDELINES"
            }
        }
    },
    "notes": {
        "enforcement_types": {
            "suggest": "Skill suggestion appears but doesn't block execution",
            "block": "Requires skill to be used before proceeding (guardrail)",
            "warn": "Shows warning but allows proceeding"
        },
        "priority_levels": {
            "critical": "Highest - Always trigger when matched",
            "high": "Important - Trigger for most matches",
            "medium": "Moderate - Trigger for clear matches",
            "low": "Optional - Trigger only for explicit matches"
        },
        "customization": {
            "pathPatterns": "Adjust to match your project structure (blog-api, auth-service, etc.)",
            "keywords": "Add domain-specific terms relevant to your project",
            "intentPatterns": "Use regex for flexible user intent matching"
        }
    }
}
